#include <iostream>
#include <unordered_map>
#include <vector>
#include <string>
#include <cstdlib>
#include <ctime>

using namespace std;

unordered_map<string, vector<double>> Q;

double alpha = 0.1;   
double gamma = 0.9;  
double epsilon = 0.2;

string getState(vector<char>& board) {
    return string(board.begin(), board.end());
}

char checkWinner(vector<char>& b) {
    int win[8][3] = {
        {0,1,2},{3,4,5},{6,7,8},
        {0,3,6},{1,4,7},{2,5,8},
        {0,4,8},{2,4,6}
    };

    for (auto &w : win) {
        if (b[w[0]] != ' ' && b[w[0]] == b[w[1]] && b[w[1]] == b[w[2]])
            return b[w[0]];
    }
    return ' ';
}

vector<int> getMoves(vector<char>& board) {
    vector<int> moves;
    for (int i = 0; i < 9; i++)
        if (board[i] == ' ') moves.push_back(i);
    return moves;
}

int chooseAction(string state, vector<int>& moves) {
    if ((double)rand() / RAND_MAX < epsilon) {
        return moves[rand() % moves.size()];
    }

    if (Q.find(state) == Q.end())
        Q[state] = vector<double>(9, 0.0);

    double best = -1e9;
    int bestMove = moves[0];

    for (int m : moves) {
        if (Q[state][m] > best) {
            best = Q[state][m];
            bestMove = m;
        }
    }
    return bestMove;
}

void train(int episodes) {
    for (int ep = 0; ep < episodes; ep++) {
        vector<char> board(9, ' ');
        vector<pair<string, int>> history;

        char player = 'X';

        while (true) {
            string state = getState(board);
            vector<int> moves = getMoves(board);

            if (moves.empty()) break;

            int action = chooseAction(state, moves);
            history.push_back({state, action});

            board[action] = player;

            char winner = checkWinner(board);
            if (winner != ' ' || getMoves(board).empty()) {
                double reward = 0;

                if (winner == 'X') reward = 1;
                else if (winner == 'O') reward = -1;

                for (int i = history.size() - 1; i >= 0; i--) {
                    string s = history[i].first;
                    int a = history[i].second;

                    if (Q.find(s) == Q.end())
                        Q[s] = vector<double>(9, 0.0);

                    Q[s][a] += alpha * (reward - Q[s][a]);
                    reward *= gamma;
                }
                break;
            }

            player = (player == 'X') ? 'O' : 'X';
        }
    }
}

void printBoard(vector<char>& b) {
    cout << "\n";
    for (int i = 0; i < 9; i++) {
        cout << (b[i] == ' ' ? '.' : b[i]) << " ";
        if ((i+1)%3 == 0) cout << "\n";
    }
    cout << "\n";
}

void play() {
    vector<char> board(9, ' ');
    char player = 'X';

    while (true) {
        printBoard(board);

        if (player == 'X') {
            int move;
            cout << "Enter move (0-8): ";
            cin >> move;
            if (board[move] != ' ') continue;
            board[move] = 'X';
        } else {
            string state = getState(board);
            vector<int> moves = getMoves(board);

            int bestMove = chooseAction(state, moves);
            board[bestMove] = 'O';
        }

        char winner = checkWinner(board);
        if (winner != ' ' || getMoves(board).empty()) {
            printBoard(board);
            if (winner == 'X') cout << "You win!\n";
            else if (winner == 'O') cout << "AI wins!\n";
            else cout << "Draw!\n";
            break;
        }

        player = (player == 'X') ? 'O' : 'X';
    }
}

int main() {
    srand(time(0));

    cout << "Training AI...\n";
    train(15000); // increase for stronger AI

    cout << "Training complete. Play!\n";
    play();

    return 0;
}
